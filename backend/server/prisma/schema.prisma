
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("STAFF") // ADMIN, MANAGER, STAFF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  otp       String?
  otpExpires DateTime?

  // Relations
  operations Operation[]
  adjustments Adjustment[]

  @@map("users")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  description String?
  category    String?
  unit        String   @default("pcs") // pcs, kg, m, etc.
  minStock    Int      @default(0)
  maxStock    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  stockLevels StockLevel[]
  operations  Operation[]
  adjustments Adjustment[]

  @@map("products")
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String?
  capacity  Int?     // in cubic meters or similar
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stockLevels StockLevel[]
  operations  Operation[] @relation("SourceWarehouse")
  destinationOperations Operation[] @relation("DestinationWarehouse")

  @@map("warehouses")
}

model StockLevel {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int       @default(0)
  location    String?   // rack/shelf location
  lastUpdated DateTime  @default(now())

  // Relations
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@map("stock_levels")
}

model Operation {
  id          String    @id @default(cuid())
  type        String    // RECEIPT, DELIVERY, TRANSFER, ADJUSTMENT
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  productId   String
  warehouseId String?
  destinationWarehouseId String?
  userId      String
  quantity    Int
  unit        String    @default("pcs")
  reference   String?   // PO number, SO number, etc.
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse? @relation("SourceWarehouse", fields: [warehouseId], references: [id])
  destinationWarehouse Warehouse? @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("operations")
}

model Adjustment {
  id        String   @id @default(cuid())
  productId String
  userId    String
  type      String   // STOCK_COUNT, DAMAGE, EXPIRY, WRITE_OFF, OTHER
  quantity  Int
  reason    String
  location  String?
  notes     String?
  createdAt DateTime @default(now())

  // Relations
  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("adjustments")
}
